# Signal account phone number (required)
# Must match the account registered with signal-cli
SIGNAL_ACCOUNT=+1234567890

# Database path (optional, default: ./exorcist.db)
DB_PATH=./exorcist.db

# Sync schedule in cron format (optional, default: every hour)
# Format: minute hour day month weekday
SYNC_SCHEDULE=0 * * * *

# Reap schedule in cron format (optional, default: daily at 2am)
# Format: minute hour day month weekday
REAP_SCHEDULE=0 2 * * *
